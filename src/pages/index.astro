---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
---

<MainGridLayout title="XingHuiSama の 博客" description="XingHuiSama の 宝藏之地">
	<section class="grid gap-4">
		<a href="/posts/leetcode-rotate-image/" class="card-base block rounded-(--radius-large) p-4 transition hover:scale-[1.01]">
			<div class="mb-3 text-xs opacity-70">Latest Insight 2026.04.15 10:57</div>
			<img
				src="https://bu.dusays.com/2026/04/15/69defe9eaf9e5.jpg"
				alt="Leetcode一百题——旋转图像"
				class="h-52 w-full rounded-lg object-cover"
				loading="lazy"
			/>
			<h2 class="mt-4 text-xl font-bold">Leetcode一百题——旋转图像</h2>
			<p class="mt-2 text-sm opacity-80">两次翻转</p>
		</a>

		<a href="/photowall/" class="card-base block rounded-(--radius-large) p-4 transition hover:scale-[1.01]">
			<img
				src="https://bu.dusays.com/2026/03/24/69c24230de927.jpg"
				alt="泰拉大陆纪行"
				class="h-48 w-full rounded-lg object-cover"
				loading="lazy"
			/>
			<div class="mt-3 text-xs opacity-70">Photo Collection</div>
			<h3 class="mt-1 text-lg font-semibold">泰拉大陆纪行</h3>
			<p class="mt-2 text-sm opacity-80">关于源石、孤星与前文明的视觉记录（测试用相册）</p>
		</a>

		<a href="/chatter/" class="card-base block rounded-(--radius-large) p-4 transition hover:scale-[1.01]">
			<div class="mb-3 text-xs opacity-70">Records 2026.04.15 16:12</div>
			<img
				src="https://bu.dusays.com/2026/04/15/69df48593a00c.jpg"
				alt="归档模组重建"
				class="h-44 w-full rounded-lg object-cover"
				loading="lazy"
			/>
			<h3 class="mt-4 text-lg font-semibold">归档模组重建</h3>
			<p class="mt-2 text-sm opacity-80">现在归档可以按照矩阵方块排序文章了，信息密度更高一些</p>
		</a>
	</section>
</MainGridLayout>
