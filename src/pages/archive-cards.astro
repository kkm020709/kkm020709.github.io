---
import ArchiveCardPanel from "@components/controls/ArchiveCardPanel.svelte";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedPostsList } from "@/utils/content-utils";

const sortedPostsList = await getSortedPostsList();
---

<MainGridLayout title="归档" description="按分类和标签浏览所有文章">
  <ArchiveCardPanel sortedPosts={sortedPostsList} client:only="svelte" />
</MainGridLayout>