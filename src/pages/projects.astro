---
import MainGridLayout from "@/layouts/MainGridLayout.astro";

type GitHubRepo = {
	name: string;
	description: string | null;
	language: string | null;
	stargazers_count: number;
	updated_at: string;
	html_url: string;
	topics?: string[];
	fork: boolean;
};

type ProjectCard = {
	projectName: string;
	projectIntro: string;
	projectStack: string[];
	stars: number;
	language: string;
	updatedAt: string;
	repoUrl: string;
	searchText: string;
};

const owner = "kkm020709";
let projects: ProjectCard[] = [];

try {
	const response = await fetch(
		`https://api.github.com/users/${owner}/repos?sort=updated&per_page=100`,
		{
			headers: {
				Accept: "application/vnd.github+json",
			},
		},
	);
	if (!response.ok) {
		throw new Error(`GitHub API request failed: ${response.status}`);
	}

	const repos = (await response.json()) as GitHubRepo[];
	projects = repos
		.filter((repo) => !repo.fork)
		.sort((a, b) => (new Date(a.updated_at) < new Date(b.updated_at) ? 1 : -1))
		.map((repo) => {
			const topicStack = (repo.topics || []).slice(0, 4).map((item) => item.toUpperCase());
			const languageStack = repo.language ? [repo.language.toUpperCase()] : [];
			const stack = [...new Set([...languageStack, ...topicStack])];
			const finalStack = stack.length > 0 ? stack : ["UNSPECIFIED"];
			const updatedAt = new Date(repo.updated_at).toLocaleDateString("zh-CN");
			const intro = (repo.description || "该仓库暂未填写项目简介。").trim();
			const searchText = `${repo.name} ${intro} ${finalStack.join(" ")}`.toLowerCase();

			return {
				projectName: repo.name,
				projectIntro: intro,
				projectStack: finalStack,
				stars: repo.stargazers_count,
				language: repo.language || "未标注",
				updatedAt,
				repoUrl: repo.html_url,
				searchText,
			};
		});
} catch {
	projects = [];
}
---

<MainGridLayout title="项目展示" description="GitHub 仓库自动同步展示">
	<div class="card-base rounded-(--radius-large) overflow-hidden w-full">
		<div class="px-6 md:px-9 py-6 md:py-8">
			<header class="mb-6 md:mb-8">
				<div class="flex items-center gap-2">
					<div class="w-1 h-5 rounded-md bg-(--primary)"></div>
					<h1 class="text-2xl md:text-3xl font-bold">项目展示</h1>
				</div>
				<p class="mt-3 text-sm md:text-base text-75">自动读取 GitHub 仓库信息，按更新时间展示。</p>
				<div class="search-shell mt-5 max-w-2xl">
					<span class="search-icon">🔍</span>
					<input
						id="projects-search-input"
						type="text"
						class="search-input"
						placeholder="搜索项目名称、描述或技术栈..."
					/>
				</div>
			</header>

			<div id="projects-grid" class="grid grid-cols-1 lg:grid-cols-2 gap-4 md:gap-5">
			{projects.length > 0 ? (
				projects.map((project) => (
					<a
						href={project.repoUrl}
						target="_blank"
						rel="noreferrer"
						class="project-card card-base rounded-(--radius-large) p-5 md:p-6 block"
						data-project-card
						data-search={project.searchText}
						aria-label={`打开项目 ${project.projectName}`}
					>
						<section>
							<div class="flex items-start justify-between gap-3">
								<div>
									<div class="section-label">项目名</div>
									<h2 class="text-xl md:text-2xl font-bold leading-tight">{project.projectName}</h2>
								</div>
								<div class="repo-open">查看仓库</div>
							</div>

							<div class="meta-row mt-3 text-sm text-75">
								<span>⭐ {project.stars}</span>
								<span>语言：{project.language}</span>
								<span>更新：{project.updatedAt}</span>
							</div>

							<div class="mt-5">
								<div class="section-label">项目简介</div>
								<p class="text-sm md:text-base text-75 leading-relaxed">{project.projectIntro}</p>
							</div>

							<div class="mt-5">
								<div class="section-label">项目技术栈</div>
								<div class="mt-2 flex flex-wrap gap-2">
									{project.projectStack.map((stackItem) => (
										<span class="tag-chip">{stackItem}</span>
									))}
								</div>
							</div>
						</section>
					</a>
				))
			) : (
				<div class="project-empty rounded-(--radius-large) p-6 text-sm opacity-80 lg:col-span-2">
					暂时无法从 GitHub API 获取仓库信息，请稍后刷新重试。
				</div>
			)}
			</div>
		</div>
	</div>
</MainGridLayout>

<script is:inline>
	(() => {
		const input = document.getElementById("projects-search-input");
		const cards = Array.from(document.querySelectorAll("[data-project-card]"));
		if (!input || cards.length === 0) return;

		const emptyId = "projects-search-empty";
		const grid = document.getElementById("projects-grid");

		const render = () => {
			const keyword = input.value.trim().toLowerCase();
			let visibleCount = 0;

			for (const card of cards) {
				const search = card.dataset.search || "";
				const matched = keyword.length === 0 || search.includes(keyword);
				card.style.display = matched ? "block" : "none";
				if (matched) visibleCount += 1;
			}

			if (!grid) return;
			const old = document.getElementById(emptyId);
			if (visibleCount === 0) {
				if (!old) {
					const empty = document.createElement("div");
					empty.id = emptyId;
					empty.className = "project-empty rounded-2xl p-6 text-sm opacity-80 lg:col-span-2";
					empty.textContent = "没有匹配的项目，请尝试其他关键词。";
					grid.appendChild(empty);
				}
			} else if (old) {
				old.remove();
			}
		};

		input.addEventListener("input", render);
	})();
</script>

<style>
	.search-shell {
		height: 44px;
		border-radius: 999px;
		display: flex;
		align-items: center;
		gap: 0.6rem;
		padding: 0 1rem;
		background: var(--btn-regular-bg);
		border: 1px solid var(--line-divider);
	}

	.search-icon {
		opacity: 0.75;
	}

	.search-input {
		flex: 1;
		background: transparent;
		border: 0;
		outline: 0;
		font-size: 0.95rem;
		color: inherit;
	}

	.project-card {
		transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
	}

	.project-card:hover {
		transform: translateY(-3px);
		border-color: var(--primary);
	}

	.section-label {
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		opacity: 0.65;
		margin-bottom: 0.35rem;
	}

	.repo-open {
		border-radius: 999px;
		padding: 0.35rem 0.75rem;
		font-size: 0.74rem;
		font-weight: 700;
		background: var(--btn-regular-bg);
		white-space: nowrap;
	}

	.meta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
	}

	.tag-chip {
		border-radius: 999px;
		font-size: 0.72rem;
		padding: 0.28rem 0.62rem;
		letter-spacing: 0.03em;
		background: var(--btn-regular-bg);
		border: 1px solid var(--line-divider);
	}

	.project-empty {
		background: var(--btn-regular-bg);
		border: 1px dashed var(--line-divider);
	}
</style>
