---
import MainGridLayout from "@/layouts/MainGridLayout.astro";

const projects = [
	{
		name: "kkm020709.github.io",
		description: "个人博客主仓库，包含 Astro 站点代码与部署配置。",
		url: "https://github.com/kkm020709/kkm020709.github.io",
		tech: ["Astro", "TypeScript", "Netlify"],
	},
	{
		name: "待添加项目",
		description: "在此处继续添加你的 GitHub 项目，一个项目一个展示块。",
		url: "https://github.com/kkm020709",
		tech: ["GitHub"],
	},
];
---

<MainGridLayout title="项目" description="我的 GitHub 项目展示">
	<section class="grid gap-4">
		{
			projects.map((project) => (
				<article class="card-base rounded-(--radius-large) p-6">
					<h2 class="text-xl font-bold">{project.name}</h2>
					<p class="mt-3 text-sm opacity-80">{project.description}</p>
					<div class="mt-4 flex flex-wrap gap-2">
						{project.tech.map((item) => (
							<span class="btn-regular rounded-md px-2 py-1 text-xs">{item}</span>
						))}
					</div>
					<a
						href={project.url}
						target="_blank"
						rel="noopener"
						class="btn-regular mt-5 inline-flex rounded-md px-3 py-2 text-sm"
					>
						查看 GitHub 项目
					</a>
				</article>
			))
		}
	</section>
</MainGridLayout>
