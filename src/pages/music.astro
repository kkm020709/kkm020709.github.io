---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
---

<MainGridLayout title="音乐" description="播放站点音乐">
	<div class="card-base rounded-(--radius-large) p-8">
		<h1 class="text-2xl font-bold">音乐播放</h1>
		<p class="mt-3 text-sm opacity-80">
			已启用站点音乐播放器。点击下面按钮后会开始播放，播放器会固定在页面右下角。
		</p>
		<button
			id="music-play-btn"
			type="button"
			class="btn-regular mt-6 rounded-lg px-5 py-2 font-medium"
		>
			播放音乐
		</button>
	</div>
</MainGridLayout>

<script is:inline>
	function tryPlayMusic() {
		const player = window.__globalAPlayer;
		if (player && player.audio && player.audio.paused) {
			player.play().catch(() => {});
		}
	}

	document.addEventListener("astro:page-load", () => {
		const button = document.getElementById("music-play-btn");
		button?.addEventListener("click", tryPlayMusic);
		setTimeout(tryPlayMusic, 200);
	});
</script>
