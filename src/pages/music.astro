---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
---

<MainGridLayout title="音乐" description="播放站点音乐">
	<div class="card-base rounded-(--radius-large) p-8">
		<h1 class="text-2xl font-bold text-90">音乐播放</h1>
		<p class="mt-3 text-sm text-75">使用网易云音乐歌单，通过侧边栏或导航栏的播放器控制。</p>
		<p class="mt-2 text-sm text-50">歌单来源：网易云音乐 - 播放器已内置在页面中。</p>
	</div>
</MainGridLayout>
