---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
---

<MainGridLayout title="音乐" description="播放站点音乐">
	<div class="card-base rounded-(--radius-large) p-8">
		<h1 class="text-2xl font-bold">音乐播放</h1>
		<p class="mt-3 text-sm opacity-80">使用网易云音乐 iframe 插件。</p>
		<div class="mt-6 flex justify-center overflow-x-auto">
			<iframe
				frameborder="no"
				border="0"
				marginwidth="0"
				marginheight="0"
				width="330"
				height="110"
				src="https://music.163.com/outchain/player?type=0&id=3136952023&auto=1&height=90"
			></iframe>
		</div>
	</div>
</MainGridLayout>
