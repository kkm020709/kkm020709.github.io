---
import { execSync } from "node:child_process";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

type UpdateItem = {
	date: string;
	year: number;
	month: number;
	day: number;
	time: string;
	summary: string;
};

const summarizeCommitToChinese = (subject: string): string => {
	const s = subject.toLowerCase();

	if (s.includes("article") || s.includes("archive")) return "调整了文章与归档相关展示。";
	if (s.includes("music")) return "优化了音乐播放与页面氛围效果。";
	if (s.includes("chatter")) return "完善了杂谈内容分区与展示逻辑。";
	if (s.includes("project")) return "更新了项目展示样式与内容结构。";
	if (s.includes("about")) return "更新了关于页信息与站点说明。";
	if (s.includes("nav") || s.includes("menu")) return "优化了导航栏与菜单交互。";
	if (s.includes("style") || s.includes("ui")) return "优化了页面视觉样式与细节。";
	if (s.includes("loading") || s.includes("speed") || s.includes("perf"))
		return "提升了页面加载速度与浏览体验。";
	if (s.includes("revert")) return "回退并整理了部分功能，保留核心体验。";
	if (s.includes("feat")) return "新增了一项站点功能。";
	if (s.includes("fix")) return "修复了一项已知问题。";
	return "优化了站点功能与使用体验。";
};

let updates: UpdateItem[] = [];
try {
	const raw = execSync(
		'git log -40 --date=format:"%Y-%m-%d %H:%M" --pretty=format:"%ad|%s"',
		{ encoding: "utf-8" },
	);
	updates = raw
		.split("\n")
		.filter(Boolean)
		.map((line) => {
			const [date = "", subject = ""] = line.split("|");
			const [datePart = "", timePart = ""] = date.split(" ");
			const [yearText = "0", monthText = "0", dayText = "0"] = datePart.split("-");
			return {
				date,
				year: Number.parseInt(yearText, 10),
				month: Number.parseInt(monthText, 10),
				day: Number.parseInt(dayText, 10),
				time: timePart,
				summary: summarizeCommitToChinese(subject),
			};
		});
} catch {
	updates = [];
}

type MonthGroup = {
	month: number;
	items: UpdateItem[];
};

type YearGroup = {
	year: number;
	months: MonthGroup[];
};

const groupedUpdates: YearGroup[] = Object.entries(
	updates.reduce<Record<number, Record<number, UpdateItem[]>>>((yearMap, item) => {
		if (!yearMap[item.year]) yearMap[item.year] = {};
		if (!yearMap[item.year][item.month]) yearMap[item.year][item.month] = [];
		yearMap[item.year][item.month].push(item);
		return yearMap;
	}, {}),
)
	.map(([year, monthMap]) => ({
		year: Number.parseInt(year, 10),
		months: Object.entries(monthMap)
			.map(([month, items]) => ({
				month: Number.parseInt(month, 10),
				items: items.sort((a, b) => {
					if (a.day !== b.day) return b.day - a.day;
					return a.time < b.time ? 1 : -1;
				}),
			}))
			.sort((a, b) => b.month - a.month),
	}))
	.sort((a, b) => b.year - a.year);
---

<MainGridLayout title="更新历史" description="站点功能更新记录">
	<section class="card-base px-8 py-6">
		{
			groupedUpdates.length > 0 ? (
				groupedUpdates.map((yearGroup) => (
					<section class="mb-4 last:mb-0">
						<div class="flex flex-row w-full items-center h-15">
							<div class="w-[15%] md:w-[10%] transition text-2xl font-bold text-right text-75">
								{yearGroup.year}
							</div>
							<div class="w-[15%] md:w-[10%]">
								<div
									class="h-3 w-3 bg-none rounded-full outline outline-(--primary) mx-auto
                  -outline-offset-2 z-50 outline-3"
								></div>
							</div>
							<div class="w-[70%] md:w-[80%] transition text-left text-50">
								{yearGroup.months.reduce((sum, month) => sum + month.items.length, 0)} 条更新
							</div>
						</div>

						{yearGroup.months.map((monthGroup) => (
							<div>
								<div class="flex flex-row w-full items-center h-10">
									<div class="w-[15%] md:w-[10%] transition text-sm font-semibold text-right text-50">
										{monthGroup.month.toString().padStart(2, "0")}月
									</div>
									<div class="w-[15%] md:w-[10%]">
										<div class="h-1.5 w-1.5 bg-(--primary) rounded-full mx-auto opacity-70"></div>
									</div>
									<div class="w-[70%] md:w-[80%] transition text-left text-30 text-sm">
										{monthGroup.items.length} 条
									</div>
								</div>

								{monthGroup.items.map((item) => (
									<article class="group btn-plain block! min-h-10 w-full rounded-lg hover:text-[initial]">
										<div class="flex flex-row justify-start items-center min-h-10 py-1">
											<div class="w-[15%] md:w-[10%] transition text-sm text-right text-50">
												{item.month.toString().padStart(2, "0")}-{item.day.toString().padStart(2, "0")}
											</div>
											<div class="w-[15%] md:w-[10%] relative dash-line h-full flex items-center">
												<div
													class="transition-all mx-auto w-1 h-1 rounded group-hover:h-5
                           bg-[oklch(0.5_0.05_var(--hue))] group-hover:bg-(--primary)
                           outline outline-4 z-50
                           outline-(--card-bg)
                           group-hover:outline-(--btn-plain-bg-hover)
                           group-active:outline-(--btn-plain-bg-active)"
												></div>
											</div>
											<div class="w-[70%] md:w-[80%] text-left pr-2">
												<div
													class="font-bold text-75 group-hover:translate-x-1 transition-all group-hover:text-(--primary)"
												>
													{item.summary}
												</div>
												<div class="text-xs text-30 mt-0.5">{item.time}</div>
											</div>
										</div>
									</article>
								))}
							</div>
						))}
					</section>
				))
			) : (
				<div class="text-sm opacity-70">
					暂无更新历史。
				</div>
			)
		}
	</section>
</MainGridLayout>
