---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getCollection } from "astro:content";
import { getPostUrlBySlug } from "@/utils/url-utils";

const chatterPosts = (await getCollection("posts", ({ data }) => {
	const visible = data.visible !== false;
	return import.meta.env.PROD ? data.draft !== true && visible : visible;
}))
	.filter((post) => {
		const category = (post.data.category || "").toLowerCase();
		const tags = (post.data.tags || []).map((tag) => tag.toLowerCase());
		return category.includes("杂谈") || tags.includes("杂谈");
	})
	.sort((a, b) => (new Date(a.data.published) > new Date(b.data.published) ? -1 : 1));
---

<MainGridLayout title="杂谈" description="与文章区分方向的日常记录和短内容">
	<section class="grid gap-4">
		{
			chatterPosts.length > 0 ? (
				chatterPosts.map((post) => (
					<article class="card-base rounded-(--radius-large) p-6">
						<div class="text-xs opacity-60">
							{new Date(post.data.published).toLocaleDateString("zh-CN")}
						</div>
						<h2 class="mt-2 text-xl font-bold">
							<a href={getPostUrlBySlug(post.id)} class="hover:text-(--primary)">
								{post.data.title}
							</a>
						</h2>
						<p class="mt-3 text-sm opacity-80">{post.data.description || "杂谈内容"}</p>
						<div class="mt-4 flex flex-wrap gap-2">
							{(post.data.tags || []).map((tag) => (
								<span class="btn-regular rounded-md px-2 py-1 text-xs">#{tag}</span>
							))}
						</div>
					</article>
				))
			) : (
				<div class="card-base rounded-(--radius-large) p-6 text-sm opacity-75">
					还没有“杂谈”内容。你可以在文章 Frontmatter 里把 `category` 或 `tags` 设置为“杂谈”，这里就会自动显示。
				</div>
			)
		}
	</section>
</MainGridLayout>
