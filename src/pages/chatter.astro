---
import MainGridLayout from "@/layouts/MainGridLayout.astro";

const records = [
	{
		title: "归档模组重建",
		time: "2026-04-15 16:12:25",
		emoji: "✨ 疲惫",
		cover: "https://bu.dusays.com/2026/04/15/69df48593a00c.jpg",
		tags: ["博客更新"],
		desc: "现在归档可以按照矩阵方块排序文章了，信息密度更高一些",
	},
	{
		title: "弹幕背景",
		time: "2026-04-15 11:25:08",
		emoji: "✨ 疲惫",
		cover: "https://bu.dusays.com/2026/04/15/69df04fa6cd56.jpg",
		tags: ["日常", "博客更新", "博客运行"],
		desc: "新添加了一个弹幕背景，做了一点小小美化",
	},
	{
		title: "守得云开见月明",
		time: "2026-04-15 09:33:33",
		emoji: "✨ Emo",
		cover: "https://bu.dusays.com/2026/04/15/69deeacc57d9d.jpg",
		tags: ["日常", "学术投稿"],
		desc: "第8次了，调整好心态，总会投中的，加油！",
	},
];
---

<MainGridLayout title="云端杂谈" description="代码、学术、提瓦特与泰拉大陆的碎片记录">
	<section class="grid gap-4">
		<h1 class="card-base rounded-(--radius-large) p-5 text-2xl font-bold">云端杂谈</h1>
		<p class="card-base rounded-(--radius-large) p-4 text-sm opacity-80">
			“ 代码、学术、提瓦特与泰拉大陆的碎片记录 ”
		</p>

		{
			records.map((item) => (
				<article class="card-base rounded-(--radius-large) p-4">
					<img src={item.cover} alt={item.title} class="h-48 w-full rounded-lg object-cover" loading="lazy" />
					<div class="mt-3 text-xs opacity-70">{item.emoji}</div>
					<div class="mt-1 text-xs opacity-60">{item.time}</div>
					<h2 class="mt-2 text-lg font-semibold">{item.title}</h2>
					<p class="mt-2 text-sm opacity-80">{item.desc}</p>
					<div class="mt-3 flex flex-wrap gap-2">
						{item.tags.map((tag) => (
							<span class="rounded-full bg-[var(--btn-plain-bg)] px-2 py-0.5 text-xs">#{tag}</span>
						))}
					</div>
				</article>
			))
		}
	</section>
</MainGridLayout>
