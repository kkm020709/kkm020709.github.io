<script is:inline>
	(function () {
		if (typeof window === "undefined") return;

		const originalTitle = document.title;
		const hiddenTitle = "页面崩溃";

		const floatingTexts = [
			"点赞+1",
			"真不错",
			"收藏啦",
			"继续加油",
			"❤",
		];

		function createFloatingEffect(x, y) {
			const effect = document.createElement("span");
			const text =
				floatingTexts[Math.floor(Math.random() * floatingTexts.length)];

			effect.textContent = text;
			effect.style.position = "fixed";
			effect.style.left = `${x}px`;
			effect.style.top = `${y}px`;
			effect.style.pointerEvents = "none";
			effect.style.zIndex = "99999";
			effect.style.fontSize = "14px";
			effect.style.fontWeight = "700";
			effect.style.color = text === "❤" ? "#ff4d6d" : "#ff5a7a";
			effect.style.transform = "translate(-50%, -50%)";
			effect.style.transition = "transform 700ms ease, opacity 700ms ease";
			effect.style.opacity = "1";

			document.body.appendChild(effect);

			requestAnimationFrame(() => {
				effect.style.transform = "translate(-50%, -130%)";
				effect.style.opacity = "0";
			});

			setTimeout(() => effect.remove(), 720);
		}

		function onVisibilityChange() {
			document.title = document.hidden ? hiddenTitle : originalTitle;
		}

		function onClick(event) {
			if (!(event.target instanceof HTMLElement)) return;
			createFloatingEffect(event.clientX, event.clientY);
		}

		function optimizeImages() {
			const images = document.querySelectorAll("img");
			images.forEach((img) => {
				if (img.closest("#netease-player-floating")) return;
				if (!img.hasAttribute("loading")) img.setAttribute("loading", "lazy");
				img.setAttribute("decoding", "async");
				if (!img.hasAttribute("fetchpriority")) img.setAttribute("fetchpriority", "low");
			});
		}

		document.addEventListener("visibilitychange", onVisibilityChange);
		document.addEventListener("click", onClick, { passive: true });
		document.addEventListener("astro:page-load", optimizeImages);
		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", optimizeImages);
		} else {
			optimizeImages();
		}
	})();
</script>
