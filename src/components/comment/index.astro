---
import type { CollectionEntry } from "astro:content";
import { commentConfig } from "@/config/commentConfig";
import Key from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import { removeFileExtension } from "@/utils/url-utils";
import Artalk from "./Artalk.astro";
import Changyan from "./Changyan.astro";
import Disqus from "./Disqus.astro";
import Giscus from "./Giscus.astro";
import Livere from "./Livere.astro";
import Twikoo from "./Twikoo.astro";
import Waline from "./Waline.astro";

interface Props {
	post: CollectionEntry<"posts"> | CollectionEntry<"spec">;
	customPath?: string;
}

const { post, customPath } = Astro.props;
const { id } = post;

const slug = removeFileExtension(id);
const path =
	customPath || (post.collection === "posts" ? `/posts/${slug}` : `/${slug}`);
const url = `${Astro.site?.href}${path}`;

let commentService: string = commentConfig?.type || "none";
---

{
  commentService !== "none" && (
    <section class="comment-shell card-base relative overflow-hidden mb-6">
      {/* 顶部装饰条 */}
      <div class="comment-accent-bar" aria-hidden="true"></div>

      {/* 背景装饰图形 */}
      <div class="pointer-events-none absolute -top-16 -right-16 w-56 h-56 opacity-[0.06]" aria-hidden="true">
        <svg viewBox="0 0 100 100" class="w-full h-full">
          <defs>
            <linearGradient id="commentGrad" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="currentColor" stop-opacity="1" />
              <stop offset="100%" stop-color="currentColor" stop-opacity="0.3" />
            </linearGradient>
          </defs>
          <circle cx="50" cy="50" r="42" fill="url(#commentGrad)" class="text-(--primary)" />
          <circle cx="50" cy="50" r="28" fill="none" stroke="currentColor" stroke-width="1.5" class="text-(--primary)" />
          <circle cx="50" cy="50" r="14" fill="currentColor" class="text-(--primary)" opacity="0.5" />
        </svg>
      </div>

      {/* 头部：标题 + 工具栏 */}
      <header class="relative z-10 px-6 md:px-8 pt-6 md:pt-8 pb-4">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
          <div class="flex items-center gap-3">
            <div class="comment-icon-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-6l-4 4v-4z" />
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold text-(--btn-content) leading-tight">
                {i18n(Key.commentSection)}
              </h3>
              <p class="text-xs text-(--content-meta) mt-0.5">
                {i18n(Key.commentSubtitle)}
              </p>
            </div>
          </div>

          {/* 右侧提示胶囊：Powered by 来必力 */}
          {commentService === "livere" && (
            <div class="comment-provider-pill" title="Powered by Livere">
              <span class="comment-dot" aria-hidden="true"></span>
              <span class="text-xs font-medium">Powered by 来必力</span>
            </div>
          )}
        </div>

        {/* 分隔线 */}
        <div class="mt-5 h-px bg-gradient-to-r from-(--line-divider) via-(--primary)/40 to-transparent"></div>
      </header>

      {/* 评论组件主体 */}
      <div class="relative z-10 px-4 md:px-6 pb-6 md:pb-8">
        {commentService === "twikoo" && <Twikoo path={path} />}
        {commentService === "waline" && <Waline path={path} />}
        {commentService === "giscus" && <Giscus />}
        {commentService === "disqus" && (
          <Disqus
            identifier={slug}
            url={url}
            title={"title" in post.data ? post.data.title : slug}
          />
        )}
        {commentService === "artalk" && <Artalk path={path} />}
        {commentService === "livere" && <Livere />}
        {commentService === "changyan" && <Changyan />}
      </div>
    </section>
  )
}

{
  commentService === "none" && (
    <section class="card-base p-8 mb-6">
      <div class="text-center py-8 text-(--content-meta)">
        <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-(--btn-regular-bg) flex items-center justify-center">
          <svg class="w-8 h-8 text-(--primary)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
            />
          </svg>
        </div>
        <p>{i18n(Key.commentNotConfigured)}</p>
      </div>
    </section>
  )
}

<style>
  .comment-shell {
    border-radius: var(--radius-large);
  }

  .comment-accent-bar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(
      90deg,
      var(--primary) 0%,
      color-mix(in srgb, var(--primary) 60%, transparent) 40%,
      transparent 100%
    );
    border-top-left-radius: inherit;
    border-top-right-radius: inherit;
    z-index: 1;
  }

  .comment-icon-wrap {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    background: color-mix(in srgb, var(--primary) 15%, transparent);
    color: var(--primary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--primary) 40%, transparent);
    flex-shrink: 0;
  }

  .comment-provider-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0.75rem;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--primary) 10%, var(--card-bg));
    border: 1px solid color-mix(in srgb, var(--primary) 25%, var(--line-divider));
    color: var(--btn-content);
    width: fit-content;
    transition: all 0.25s ease;
  }

  .comment-provider-pill:hover {
    background: color-mix(in srgb, var(--primary) 18%, var(--card-bg));
    transform: translateY(-1px);
    box-shadow: 0 6px 14px -4px color-mix(in srgb, var(--primary) 30%, transparent);
  }

  .comment-dot {
    width: 7px;
    height: 7px;
    border-radius: 9999px;
    background: var(--primary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--primary) 25%, transparent);
    animation: comment-dot-pulse 2s ease-in-out infinite;
  }

  @keyframes comment-dot-pulse {
    0%, 100% {
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--primary) 40%, transparent);
    }
    50% {
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--primary) 0%, transparent);
    }
  }
</style>
