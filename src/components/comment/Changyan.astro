---
import { commentConfig } from "@/config";

if (
	!commentConfig ||
	!commentConfig.changyan?.appid ||
	!commentConfig.changyan?.conf
) {
	throw new Error("Changyan comments are not configured");
}

const { appid, conf } = commentConfig.changyan;
---

{/* 预连接 Changyan CDN，缩短 DNS / TLS 握手时间，显著提升加载速度 */}
<link rel="dns-prefetch" href="https://cy-cdn.kuaizhan.com" slot="head" />
<link rel="preconnect" href="https://cy-cdn.kuaizhan.com" crossorigin slot="head" />
<link rel="dns-prefetch" href="https://changyan.kuaizhan.com" slot="head" />
<link rel="preconnect" href="https://changyan.kuaizhan.com" crossorigin slot="head" />

<div class="changyan-wrapper" data-changyan-state="idle">
  {/* 骨架屏：在脚本注入完成前先渲染，避免长时间空白 */}
  <div class="changyan-skeleton" aria-hidden="true">
    <div class="changyan-skeleton-login">
      <div class="cy-skel-avatar"></div>
      <div class="cy-skel-input"></div>
      <div class="cy-skel-btn"></div>
    </div>
    <div class="changyan-skeleton-item">
      <div class="cy-skel-avatar-sm"></div>
      <div class="cy-skel-lines">
        <div class="cy-skel-line w-32"></div>
        <div class="cy-skel-line w-full"></div>
        <div class="cy-skel-line w-3/4"></div>
      </div>
    </div>
    <div class="changyan-skeleton-hint">
      <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-opacity="0.25"></circle>
        <path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"></path>
      </svg>
      <span>正在加载畅言云评…</span>
    </div>
  </div>

  {/* Changyan 官方容器 */}
  <div id="SOHUCS" sid={Astro.url.pathname}></div>
</div>

<script is:inline define:vars={{ appid, conf }}>
  /*
   * Changyan 懒加载 + 首屏提速
   * 1. 不在页面解析时立即拉取 changyan.js，而是通过 IntersectionObserver
   *    在评论区接近视口时才加载，首屏 JS 体积 / 请求数降到最低。
   * 2. 若浏览器不支持 IntersectionObserver 或加载后 4s 内评论未就绪，
   *    自动降级为 requestIdleCallback / setTimeout 兜底。
   * 3. 先检查 window.__CHANGYAN_LOADED 避免多个实例重复注入脚本。
   */
  (function () {
    var wrapper = document.currentScript.parentElement.querySelector(
      ".changyan-wrapper[data-changyan-state='idle']"
    );
    if (!wrapper) return;
    var sohucs = wrapper.querySelector("#SOHUCS");
    if (!sohucs) return;

    function markLoading() {
      wrapper.setAttribute("data-changyan-state", "loading");
    }
    function markReady() {
      wrapper.setAttribute("data-changyan-state", "ready");
    }

    // 监听 Changyan 注入内容：一旦 #SOHUCS 出现子元素即视为就绪
    var observer = new MutationObserver(function () {
      if (sohucs.childElementCount > 0) {
        markReady();
        observer.disconnect();
      }
    });
    try {
      observer.observe(sohucs, { childList: true, subtree: true });
    } catch (_) {}

    // 最长 10s 强制结束骨架屏
    setTimeout(function () {
      if (wrapper.getAttribute("data-changyan-state") !== "ready") {
        markReady();
        try { observer.disconnect(); } catch (_) {}
      }
    }, 10000);

    function injectChangyan() {
      if (window.__CHANGYAN_LOADED) return;
      window.__CHANGYAN_LOADED = true;
      markLoading();

      var width = window.innerWidth || document.documentElement.clientWidth;
      var head =
        document.getElementsByTagName("head")[0] ||
        document.head ||
        document.documentElement;

      if (width < 1000) {
        var mscript = document.createElement("script");
        mscript.type = "text/javascript";
        mscript.charset = "utf-8";
        mscript.async = true;
        mscript.id = "changyan_mobile_js";
        mscript.src =
          "https://cy-cdn.kuaizhan.com/upload/mobile/wap-js/changyan_mobile.js?client_id=" +
          appid +
          "&conf=" +
          conf;
        head.appendChild(mscript);
      } else {
        var loadJs = function (d, a) {
          var b = document.createElement("script");
          b.setAttribute("type", "text/javascript");
          b.setAttribute("charset", "UTF-8");
          b.setAttribute("src", d);
          b.async = true;
          if (typeof a === "function") {
            if (window.attachEvent) {
              b.onreadystatechange = function () {
                var e = b.readyState;
                if (e === "loaded" || e === "complete") {
                  b.onreadystatechange = null;
                  a();
                }
              };
            } else {
              b.onload = a;
            }
          }
          head.appendChild(b);
        };
        loadJs("https://cy-cdn.kuaizhan.com/upload/changyan.js", function () {
          if (window.changyan && window.changyan.api) {
            window.changyan.api.config({ appid: appid, conf: conf });
          }
        });
      }
    }

    // 使用 IntersectionObserver 在评论区即将进入视口时再加载
    if ("IntersectionObserver" in window) {
      var io = new IntersectionObserver(
        function (entries) {
          for (var i = 0; i < entries.length; i++) {
            if (entries[i].isIntersecting) {
              injectChangyan();
              io.disconnect();
              break;
            }
          }
        },
        { rootMargin: "400px 0px" }
      );
      io.observe(wrapper);

      // 兜底：6s 后仍未进入视口（例如页面短于视口），强制加载
      setTimeout(function () {
        if (!window.__CHANGYAN_LOADED) injectChangyan();
      }, 6000);
    } else {
      // 不支持 IO 的老浏览器：空闲时加载
      if ("requestIdleCallback" in window) {
        window.requestIdleCallback(injectChangyan, { timeout: 2000 });
      } else {
        setTimeout(injectChangyan, 800);
      }
    }
  })();
</script>

<style is:global>
  /* =============================================================
     畅言云评 —— 使用官方默认样式；仅做最小必要调整：
     1) 登录弹窗居中、遮罩全屏、层级置顶（修复弹窗被截断的问题）
     2) 隐藏官方广告/新闻推荐条
     3) 加载骨架屏（显著优化首屏观感）
     ============================================================= */

  .changyan-wrapper {
    position: relative;
    min-height: 200px;
  }

  /* ---------- 骨架屏 ---------- */
  .changyan-skeleton {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 0.5rem 0 0.75rem;
  }
  .changyan-wrapper[data-changyan-state="ready"] .changyan-skeleton {
    display: none;
  }
  .changyan-wrapper[data-changyan-state="ready"] #SOHUCS {
    opacity: 1;
    transition: opacity 0.35s ease;
  }
  .changyan-wrapper[data-changyan-state="idle"] #SOHUCS,
  .changyan-wrapper[data-changyan-state="loading"] #SOHUCS {
    opacity: 0;
    pointer-events: none;
    height: 0;
    overflow: hidden;
  }

  .changyan-skeleton-login {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--line-divider);
    background: var(--card-bg);
    border-radius: 0.75rem;
  }
  .cy-skel-avatar,
  .cy-skel-avatar-sm {
    border-radius: 9999px;
    background: var(--btn-regular-bg);
    flex-shrink: 0;
    animation: changyan-pulse 1.6s ease-in-out infinite;
  }
  .cy-skel-avatar { width: 40px; height: 40px; }
  .cy-skel-avatar-sm { width: 32px; height: 32px; }
  .cy-skel-input {
    flex: 1;
    height: 40px;
    border-radius: 0.5rem;
    background: var(--btn-regular-bg);
    animation: changyan-pulse 1.6s ease-in-out infinite;
  }
  .cy-skel-btn {
    width: 80px;
    height: 40px;
    border-radius: 0.5rem;
    background: color-mix(in srgb, var(--primary) 28%, var(--btn-regular-bg));
    animation: changyan-pulse 1.6s ease-in-out infinite;
  }
  .changyan-skeleton-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--line-divider);
  }
  .cy-skel-lines {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .cy-skel-line {
    height: 0.7rem;
    border-radius: 0.25rem;
    background: var(--btn-regular-bg);
    animation: changyan-pulse 1.6s ease-in-out infinite;
  }
  .changyan-skeleton-hint {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    color: var(--content-meta);
    font-size: 0.85rem;
    padding: 0.25rem 0;
  }
  @keyframes changyan-pulse {
    0%, 100% { opacity: 0.55; }
    50% { opacity: 1; }
  }

  /* ---------- 隐藏官方广告 / 推荐 ---------- */
  #SOHUCS .section-service-w,
  #SOHUCS .section-newslist-w,
  #SOHUCS .news-list-dw,
  #SOHUCS .section-ads-w,
  #SOHUCS .section-serviceh-w,
  #SOHUCS .section-advertisement,
  #SOHUCS .advertisement-dw,
  #SOHUCS .cy-ad {
    display: none !important;
    height: 0 !important;
  }

  /* ---------- 登录弹窗定位修复（解决右侧被截断、层级混乱） ---------- */
  /* 背后的遮罩：全屏固定 */
  .login-overlay-dw,
  .mask-dw,
  .cy-mask-dw,
  .mask-login-dw,
  .module-mask-dw {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    right: 0 !important;
    bottom: 0 !important;
    width: 100vw !important;
    height: 100vh !important;
    background: rgba(0, 0, 0, 0.55) !important;
    backdrop-filter: blur(2px) !important;
    -webkit-backdrop-filter: blur(2px) !important;
    z-index: 99998 !important;
    margin: 0 !important;
    transform: none !important;
  }

  /* 登录弹窗主体：屏幕正中、在视口内可见 */
  .user-login-wrapper-dw,
  .visitor-login-wrapper-dw,
  .module-login-dw,
  .module-loginbox-dw,
  .section-login-pop-w,
  .login-pop-dw,
  .cy-login-wrapper-dw,
  .login-wrapper-dw {
    position: fixed !important;
    top: 50% !important;
    left: 50% !important;
    right: auto !important;
    bottom: auto !important;
    transform: translate(-50%, -50%) !important;
    margin: 0 !important;
    z-index: 99999 !important;
    max-width: min(92vw, 420px) !important;
    max-height: 90vh !important;
    overflow: auto !important;
    border-radius: 12px !important;
    box-shadow: 0 20px 60px -10px rgba(0, 0, 0, 0.35) !important;
  }

  /* 有时 Changyan 会把弹窗放在 #SOHUCS 内部（相对定位），强制脱离 */
  #SOHUCS .user-login-wrapper-dw,
  #SOHUCS .visitor-login-wrapper-dw,
  #SOHUCS .module-login-dw,
  #SOHUCS .module-loginbox-dw,
  #SOHUCS .section-login-pop-w,
  #SOHUCS .login-pop-dw,
  #SOHUCS .cy-login-wrapper-dw,
  #SOHUCS .login-wrapper-dw {
    position: fixed !important;
    top: 50% !important;
    left: 50% !important;
    transform: translate(-50%, -50%) !important;
  }

  /* 弹窗内关闭按钮保持可点击 */
  .user-login-wrapper-dw .close-dw,
  .visitor-login-wrapper-dw .close-dw,
  .module-login-dw .close-dw,
  .module-loginbox-dw .close-dw {
    z-index: 100000 !important;
  }

  /* 移动端弹窗适配 */
  @media (max-width: 640px) {
    .user-login-wrapper-dw,
    .visitor-login-wrapper-dw,
    .module-login-dw,
    .module-loginbox-dw,
    .section-login-pop-w,
    .login-pop-dw,
    .cy-login-wrapper-dw,
    .login-wrapper-dw {
      max-width: 94vw !important;
      width: 94vw !important;
    }
  }
</style>
