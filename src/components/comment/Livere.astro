---
import { commentConfig } from "@/config";

if (!commentConfig || !commentConfig.livere?.clientId) {
	throw new Error("Livere comments are not configured");
}

const clientId = commentConfig.livere.clientId;
---

<div class="livere-wrapper relative" data-livere-ready="false">
  {/* 加载骨架屏：Livere widget 渲染完成前显示 */}
  <div class="livere-skeleton" aria-hidden="true">
    <div class="skeleton-login">
      <div class="skeleton-avatar"></div>
      <div class="skeleton-input"></div>
      <div class="skeleton-btn"></div>
    </div>
    <div class="skeleton-list">
      <div class="skeleton-item">
        <div class="skeleton-avatar-sm"></div>
        <div class="skeleton-lines">
          <div class="skeleton-line w-32"></div>
          <div class="skeleton-line w-full"></div>
          <div class="skeleton-line w-3/4"></div>
        </div>
      </div>
      <div class="skeleton-item">
        <div class="skeleton-avatar-sm"></div>
        <div class="skeleton-lines">
          <div class="skeleton-line w-24"></div>
          <div class="skeleton-line w-5/6"></div>
        </div>
      </div>
    </div>
    <div class="skeleton-hint">
      <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-opacity="0.25"></circle>
        <path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"></path>
      </svg>
      <span>正在加载来必力评论系统…</span>
    </div>
  </div>

  {/* Livere 评论容器 */}
  <livere-comment class="livere-widget" client-id={clientId}></livere-comment>
</div>

<script type="module" src="https://www.livere.org/livere-widget.js"></script>

<script is:inline>
  (function () {
    const wrapper = document.currentScript.previousElementSibling
      ? document.currentScript.parentElement.querySelector(".livere-wrapper[data-livere-ready='false']")
      : null;
    if (!wrapper) return;

    const widget = wrapper.querySelector("livere-comment");
    if (!widget) return;

    let timedOut = false;
    const timer = setTimeout(() => {
      timedOut = true;
      wrapper.setAttribute("data-livere-ready", "true");
    }, 8000);

    const observer = new MutationObserver(() => {
      // Livere 的 widget 渲染完成后，内部会出现子元素（或 shadowRoot）
      const hasContent = widget.shadowRoot
        ? widget.shadowRoot.childElementCount > 0
        : widget.childElementCount > 0;
      if (hasContent) {
        clearTimeout(timer);
        wrapper.setAttribute("data-livere-ready", "true");
        observer.disconnect();
      }
    });

    try {
      observer.observe(widget, { childList: true, subtree: true });
    } catch (_) {
      // noop
    }

    // 额外保险：轮询 shadowRoot（某些版本 MutationObserver 观察不到 shadowRoot 变化）
    const poll = setInterval(() => {
      if (timedOut) {
        clearInterval(poll);
        return;
      }
      const ready = widget.shadowRoot
        ? widget.shadowRoot.childElementCount > 0
        : widget.childElementCount > 0;
      if (ready) {
        clearTimeout(timer);
        wrapper.setAttribute("data-livere-ready", "true");
        observer.disconnect();
        clearInterval(poll);
      }
    }, 400);
  })();
</script>

<style is:global>
  /* ==========================================================================
     来必力 (Livere) 评论系统 —— UI 与网站风格保持一致
     ========================================================================== */

  .livere-wrapper {
    min-height: 220px;
  }

  /* 暴露站点主题色给 Livere 内部（部分版本支持 CSS 变量继承） */
  .livere-wrapper livere-comment {
    display: block;
    width: 100%;
    --primary-color: var(--primary);
    --livere-primary: var(--primary);
    --livere-bg: var(--card-bg);
    --livere-text: var(--btn-content);
    --livere-border: var(--line-divider);
    color: var(--btn-content);
    font-family: inherit;
  }

  /* ----------- 加载骨架屏 ----------- */
  .livere-skeleton {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 0.25rem 0 0.75rem;
  }

  .livere-wrapper[data-livere-ready="true"] .livere-skeleton {
    display: none;
  }

  .livere-wrapper[data-livere-ready="false"] livere-comment {
    opacity: 0;
    pointer-events: none;
    height: 0;
    overflow: hidden;
  }

  .livere-wrapper[data-livere-ready="true"] livere-comment {
    opacity: 1;
    height: auto;
    transition: opacity 0.3s ease;
  }

  .skeleton-login {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    border: 1px solid var(--line-divider);
    background: var(--card-bg);
    border-radius: 0.75rem;
  }

  .skeleton-avatar {
    width: 40px;
    height: 40px;
    border-radius: 9999px;
    background: var(--btn-regular-bg);
    flex-shrink: 0;
    animation: livere-pulse 1.6s ease-in-out infinite;
  }

  .skeleton-avatar-sm {
    width: 32px;
    height: 32px;
    border-radius: 9999px;
    background: var(--btn-regular-bg);
    flex-shrink: 0;
    animation: livere-pulse 1.6s ease-in-out infinite;
  }

  .skeleton-input {
    flex: 1;
    height: 40px;
    border-radius: 0.5rem;
    background: var(--btn-regular-bg);
    animation: livere-pulse 1.6s ease-in-out infinite;
  }

  .skeleton-btn {
    width: 80px;
    height: 40px;
    border-radius: 0.5rem;
    background: color-mix(in srgb, var(--primary) 30%, var(--btn-regular-bg));
    animation: livere-pulse 1.6s ease-in-out infinite;
  }

  .skeleton-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .skeleton-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--line-divider);
  }

  .skeleton-lines {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .skeleton-line {
    height: 0.75rem;
    border-radius: 0.25rem;
    background: var(--btn-regular-bg);
    animation: livere-pulse 1.6s ease-in-out infinite;
  }

  .skeleton-hint {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.5rem 0;
    color: var(--content-meta);
    font-size: 0.85rem;
  }

  @keyframes livere-pulse {
    0%, 100% { opacity: 0.55; }
    50% { opacity: 1; }
  }

  /* ----------- 针对 Livere 内部（非 Shadow DOM 版本）的样式覆盖 ----------- */

  /* 外层容器 */
  .livere-wrapper #lv-container,
  .livere-wrapper .livere-wrapper-box,
  .livere-wrapper .livere-container {
    background: transparent !important;
    color: var(--btn-content) !important;
    font-family: inherit !important;
  }

  /* 登录/评论输入栏 */
  .livere-wrapper .livere-login-area,
  .livere-wrapper .livere-editor,
  .livere-wrapper .livere-textarea-wrapper {
    background: var(--card-bg) !important;
    border: 1px solid var(--line-divider) !important;
    border-radius: 0.75rem !important;
    padding: 1rem !important;
    transition: border-color 0.2s ease, box-shadow 0.2s ease !important;
  }

  .livere-wrapper .livere-login-area:focus-within,
  .livere-wrapper .livere-editor:focus-within,
  .livere-wrapper .livere-textarea-wrapper:focus-within {
    border-color: var(--primary) !important;
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--primary) 15%, transparent) !important;
  }

  /* 输入框/文本域 */
  .livere-wrapper textarea,
  .livere-wrapper input[type="text"],
  .livere-wrapper input[type="email"],
  .livere-wrapper .livere-textarea {
    background: var(--card-bg) !important;
    color: var(--btn-content) !important;
    border: 1px solid var(--line-divider) !important;
    border-radius: 0.5rem !important;
    padding: 0.65rem 0.9rem !important;
    font-family: inherit !important;
    transition: border-color 0.2s ease, box-shadow 0.2s ease !important;
  }

  .livere-wrapper textarea:focus,
  .livere-wrapper input[type="text"]:focus,
  .livere-wrapper input[type="email"]:focus,
  .livere-wrapper .livere-textarea:focus {
    outline: none !important;
    border-color: var(--primary) !important;
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--primary) 20%, transparent) !important;
  }

  .livere-wrapper textarea::placeholder,
  .livere-wrapper input::placeholder {
    color: var(--content-meta) !important;
    opacity: 0.7 !important;
  }

  /* 按钮 */
  .livere-wrapper button,
  .livere-wrapper .livere-btn,
  .livere-wrapper .livere-submit-btn,
  .livere-wrapper .livere-login-btn {
    background: var(--btn-regular-bg) !important;
    color: var(--btn-content) !important;
    border: 1px solid var(--line-divider) !important;
    border-radius: 0.5rem !important;
    padding: 0.5rem 1.25rem !important;
    height: auto !important;
    font-weight: 500 !important;
    font-family: inherit !important;
    cursor: pointer !important;
    transition: all 0.25s ease !important;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05) !important;
  }

  .livere-wrapper button:hover,
  .livere-wrapper .livere-btn:hover,
  .livere-wrapper .livere-submit-btn:hover,
  .livere-wrapper .livere-login-btn:hover {
    background: var(--btn-regular-bg-hover) !important;
    border-color: var(--primary) !important;
    transform: translateY(-1px) !important;
    box-shadow: 0 4px 10px -2px color-mix(in srgb, var(--primary) 25%, transparent) !important;
  }

  .livere-wrapper button:active,
  .livere-wrapper .livere-btn:active,
  .livere-wrapper .livere-submit-btn:active {
    transform: translateY(0) scale(0.98) !important;
    background: var(--btn-regular-bg-active) !important;
  }

  /* 主操作按钮（发布评论） */
  .livere-wrapper .livere-btn-primary,
  .livere-wrapper button[type="submit"],
  .livere-wrapper .submit,
  .livere-wrapper .livere-post-btn {
    background: var(--primary) !important;
    color: white !important;
    border-color: transparent !important;
  }

  .livere-wrapper .livere-btn-primary:hover,
  .livere-wrapper button[type="submit"]:hover,
  .livere-wrapper .submit:hover,
  .livere-wrapper .livere-post-btn:hover {
    background: color-mix(in srgb, var(--primary) 88%, black) !important;
    color: white !important;
    transform: translateY(-1px) !important;
    box-shadow: 0 6px 16px -2px color-mix(in srgb, var(--primary) 40%, transparent) !important;
  }

  /* 工具栏（表情、图片等）置于输入框下方 */
  .livere-wrapper .livere-toolbar,
  .livere-wrapper .livere-actions {
    display: flex !important;
    gap: 0.5rem !important;
    align-items: center !important;
    margin-top: 0.75rem !important;
    padding-top: 0.75rem !important;
    border-top: 1px dashed var(--line-divider) !important;
  }

  /* 提交按钮区域放到底部右侧 */
  .livere-wrapper .livere-btn-area,
  .livere-wrapper .livere-footer {
    display: flex !important;
    justify-content: flex-end !important;
    gap: 0.5rem !important;
    margin-top: 0.75rem !important;
  }

  /* 评论列表项 */
  .livere-wrapper .livere-comment,
  .livere-wrapper .livere-list-item,
  .livere-wrapper .comment-item {
    border: 1px solid var(--line-divider) !important;
    border-radius: 0.75rem !important;
    padding: 1rem !important;
    margin-bottom: 0.75rem !important;
    background: var(--card-bg) !important;
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease !important;
  }

  .livere-wrapper .livere-comment:hover,
  .livere-wrapper .livere-list-item:hover,
  .livere-wrapper .comment-item:hover {
    border-color: var(--primary) !important;
    transform: translateY(-1px) !important;
    box-shadow: 0 6px 18px -4px rgba(0, 0, 0, 0.08) !important;
  }

  /* 头像 */
  .livere-wrapper .livere-avatar,
  .livere-wrapper img.avatar,
  .livere-wrapper .avatar img {
    border-radius: 9999px !important;
    border: 2px solid var(--line-divider) !important;
  }

  /* 用户名 */
  .livere-wrapper .livere-nickname,
  .livere-wrapper .livere-user-name,
  .livere-wrapper .nickname {
    color: var(--primary) !important;
    font-weight: 600 !important;
  }

  /* 时间/元信息 */
  .livere-wrapper .livere-time,
  .livere-wrapper .livere-meta,
  .livere-wrapper .time {
    color: var(--content-meta) !important;
    font-size: 0.8rem !important;
  }

  /* 链接 */
  .livere-wrapper a {
    color: var(--primary) !important;
    text-decoration: none !important;
    transition: opacity 0.2s ease !important;
  }

  .livere-wrapper a:hover {
    opacity: 0.8 !important;
    text-decoration: underline !important;
  }

  /* 标签 / tab */
  .livere-wrapper .livere-tab,
  .livere-wrapper .livere-tabs li {
    color: var(--content-meta) !important;
    border-radius: 0.5rem !important;
    padding: 0.25rem 0.75rem !important;
    transition: all 0.2s ease !important;
  }

  .livere-wrapper .livere-tab.active,
  .livere-wrapper .livere-tabs li.active {
    background: var(--btn-regular-bg) !important;
    color: var(--primary) !important;
  }

  /* ----------- 针对使用 Shadow DOM 的 Livere 版本 ----------- */
  /* 通过 ::part 暴露的部件进行主题化 */
  livere-comment::part(container) {
    background: transparent;
    color: var(--btn-content);
    font-family: inherit;
  }

  livere-comment::part(button),
  livere-comment::part(submit) {
    background: var(--btn-regular-bg);
    color: var(--btn-content);
    border: 1px solid var(--line-divider);
    border-radius: 0.5rem;
  }

  livere-comment::part(primary-button) {
    background: var(--primary);
    color: white;
    border: none;
    border-radius: 0.5rem;
  }

  livere-comment::part(input),
  livere-comment::part(textarea) {
    background: var(--card-bg);
    color: var(--btn-content);
    border: 1px solid var(--line-divider);
    border-radius: 0.5rem;
  }

  /* 暗色模式微调 */
  html.dark .livere-wrapper .livere-comment,
  html.dark .livere-wrapper .livere-list-item,
  html.dark .livere-wrapper .comment-item {
    background: color-mix(in srgb, var(--card-bg) 96%, white);
  }
</style>
